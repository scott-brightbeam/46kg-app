NODE_ENV=development
APP_TIME_ZONE=Europe/London

API_PORT=3001
API_BASE_URL=http://localhost:3001
# Browser origin used for the dashboard, CORS, and trusted-origin checks on
# cookie-authenticated write routes.
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/codex_health
# Optional fallback defaults until nutrition targets are saved in-app.
DAILY_CALORIE_TARGET=
DAILY_PROTEIN_TARGET=
DAILY_FIBRE_TARGET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_CHAT_ID=
ENABLE_OPERATOR_ALERTS=true

HEALTH_AUTO_EXPORT_SHARED_SECRET=
HEVY_API_KEY=
# Apple Fitness / Apple Workout via HealthKit is the default cardio path for v1.
# Strava remains optional and disabled by default.
ENABLE_STRAVA_SYNC=false
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

AUTH_SESSION_SECRET=

BACKUP_PGDUMP_BIN=pg_dump
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_PREFIX=postgres
BACKUP_S3_FORCE_PATH_STYLE=false

DASHBOARD_USER_EMAIL=
DASHBOARD_USER_PASSWORD=
DASHBOARD_USER_DISPLAY_NAME=
DASHBOARD_TRAINER_EMAIL=
DASHBOARD_TRAINER_PASSWORD=
DASHBOARD_TRAINER_DISPLAY_NAME=
DASHBOARD_NUTRITIONIST_EMAIL=
DASHBOARD_NUTRITIONIST_PASSWORD=
DASHBOARD_NUTRITIONIST_DISPLAY_NAME=
